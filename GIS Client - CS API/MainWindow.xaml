<Window x:Class="GIS_Client___CS_API.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Height="650"
        Width="450"
        Background="#7FB3C8"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"

        Topmost="True">

    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="45"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0"
                Background="#E5E7E9"
                MouseDown="Header_MouseDown">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="10,0,0,0">

                    <Image Source="/Images/logo.jpeg"
                           Width="26"
                           Height="26"
                           Margin="0,0,8,0"/>

                    <TextBlock Text="JETSCI Direct Print Simplex"
                               FontSize="17"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Foreground="Black"/>

                    <Border Background="#2E86C1"
                            CornerRadius="10"
                            Padding="6,2"
                            Margin="10,0,0,0"
                            VerticalAlignment="Center">
                        <TextBlock Text="Version 2.0"
                                   Foreground="White"
                                   FontSize="12"
                                   FontWeight="Bold"/>
                    </Border>

                    <Ellipse x:Name="ConnectionIndicator"
                             Width="10"
                             Height="10"
                             Fill="Red"
                             Margin="5,0,0,0"
                             VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button Content="—"
                            Width="40"
                            Height="30"
                            Background="Transparent"
                            BorderThickness="0"
                            Click="BtnMinimize_Click"/>
                    <Button Content="✖"
                            Width="40"
                            Height="30"
                            Background="Transparent"
                            BorderThickness="0"
                            Click="BtnClose_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- MAIN -->
        <Grid Grid.Row="1" Margin="20">

            <GroupBox Header="Client Settings 1"
                      Margin="5"
                      Background="#7FB3C8"
                      BorderBrush="#5DA6C6"
                      BorderThickness="1">

                <Grid Margin="15">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <!--0-->
                        <RowDefinition Height="Auto"/>
                        <!--1-->
                        <RowDefinition Height="Auto"/>
                        <!--2-->
                        <RowDefinition Height="Auto"/>
                        <!--3-->
                        <RowDefinition Height="Auto"/>
                        <!--4-->
                        <RowDefinition Height="Auto"/>
                        <!--5-->
                        <RowDefinition Height="Auto"/>
                        <!--6-->
                        <RowDefinition Height="Auto"/>
                        <!--7-->
                        <RowDefinition Height="Auto"/>
                        <!--8-->
                        <RowDefinition Height="Auto"/>
                        <!--9-->
                        <RowDefinition Height="Auto"/>
                        <!--10-->
                        <RowDefinition Height="Auto"/>
                        <!--11-->
                        <RowDefinition Height="Auto"/>
                        <!--12-->
                        <RowDefinition Height="Auto"/>
                        <!--13-->
                        <RowDefinition Height="Auto"/>
                        <!--14-->
                        <RowDefinition Height="Auto"/>
                        <!-- Row 15 -->
                        <RowDefinition Height="Auto"/>
                        <!-- Row 16 -->
                      
                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="130"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Remote Address -->
                    <TextBlock Text="Remote Address" Grid.Row="0"/>
                    <TextBox x:Name="addressTextBox1"
                             Grid.Row="0"
                             Grid.Column="1"
                             Margin="-20,2,10,0"
                             Grid.ColumnSpan="2"
                             Text="localhost"
                             Height="23"
                             Width="450"/>

                    <!-- Remote Port -->
                    <TextBlock Text="Remote Port" Grid.Row="1" Margin="0,8,0,0"/>
                    <TextBox x:Name="portTextBox1"
                             Grid.Row="1"
                             Grid.Column="1"
                             Grid.ColumnSpan="2"
                             Margin="-28,8,0,10"
                             Text="2000"
                             Height="23"
                             Width="210"/>

                    <!-- Status -->
                    <Border Grid.Row="2"
                            Grid.ColumnSpan="3"
                            Margin="-10,8,0,0"
                            Background="#F8F9F9"
                            Padding="6"
                            CornerRadius="4"
                            Width="350">
                        <TextBlock>
                            <Run Text="Status : "/>
                            <Run x:Name="statusText1"
                                 Text="Not connected"
                                 Foreground="Red"
                                 FontWeight="Bold"/>
                        </TextBlock>
                    </Border>

                    <!-- Connected Since -->
                    <TextBlock x:Name="LblConnectionTime"
                               Grid.Row="3"
                               Grid.ColumnSpan="3"
                               Margin="0,4,0,0"
                               Foreground="#566573"
                               FontSize="12"
                               Visibility="Collapsed"
                               Text="Connected since: --"/>

                    <!-- Connect / Disconnect -->
                    <StackPanel Grid.Row="4"
                                Grid.ColumnSpan="3"
                                Orientation="Horizontal"
                                Margin="0,8,0,10">
                        <Button Content="Connect"
                                Width="90"
                                Margin="0,0,10,0"
                                Click="connectButton1_Click"/>
                        <Button Content="Disconnect"
                                Width="90"
                                Click="disconnectButton1_Click"/>
                    </StackPanel>

                    <!-- Time -->
                    <!-- Time + Frequency + Spit in ONE LINE -->
                    <Grid Grid.Row="5" Grid.ColumnSpan="4" Margin="0,12,0,10">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <!-- Time -->
                            <ColumnDefinition Width="70"/>
                            <!-- Time box -->
                            <ColumnDefinition Width="Auto"/>
                            <!-- Sec -->
                            <ColumnDefinition Width="25"/>
                            <!-- Spacer -->
                            <ColumnDefinition Width="Auto"/>
                            <!-- Freq -->
                            <ColumnDefinition Width="80"/>
                            <!-- Freq box -->
                            <ColumnDefinition Width="Auto"/>
                            <!-- Hz -->
                            <ColumnDefinition Width="40"/>
                            <!-- Spacer -->
                            <ColumnDefinition Width="Auto"/>
                            <!-- Button -->
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Time" VerticalAlignment="Center"/>

                        <TextBox x:Name="Txtspit1"
             Grid.Column="1"
             Height="23"
             Text="1"
             Margin="15,0,0,0"
             HorizontalContentAlignment="Center"/>

                        <TextBlock Text="Sec"
               Grid.Column="2"
               VerticalAlignment="Center"
               Margin="5,0"/>

                        <TextBlock Text="Freq."
               Grid.Column="4"
               VerticalAlignment="Center"/>

                        <TextBox x:Name="Txtfre1"
             Grid.Column="5"
             Height="23"
             Text="300"
             Margin="5,0,0,0"                    
             HorizontalContentAlignment="Center"/>

                        <TextBlock Text="Hz"
               Grid.Column="6"
               VerticalAlignment="Center"
               Margin="5,0"/>
                        
                        <Button Content="Spit"
            Grid.Column="8"
            Width="50"
            Margin="-25,0,0,0"
            Click="BtnSpit1_Click"/>

                    </Grid>

                    <!-- Print Shift X -->
                    <!-- Print Shift X -->
                    <TextBlock Text="Print Shift_X(mm)"
           Grid.Row="7"
           VerticalAlignment="Center"/>

                    <Grid Grid.Row="7"
      Grid.Column="1"
      Grid.ColumnSpan="2"
      Margin="0,10,0,0">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Button Content="-"
            Width="25"
            Click="BtnShiftMinusX1_Click"/>

                        <TextBox x:Name="TxtPrintShift1"
             Grid.Column="1"
             Height="23"
             HorizontalContentAlignment="Center"/>

                        <Button Content="+"
            Grid.Column="2"
            Width="25"
            Click="BtnShiftPlusSmallX1_Click"/>

                        <Button Content=">>"
            Grid.Column="4"
            Width="50"
            Click="BtnShiftPlusX1_Click"/>

                    </Grid>

                    <!-- Current Value Below Title -->
                    
                    <TextBlock x:Name="LblPrintingpageX1"
           Grid.Row="8"
           Grid.ColumnSpan="3"
           Margin="0,5,0,0"
           FontWeight="Bold"
           Text="Current Value: 0.0"/>


                    
                   


                    <!-- Print Shift Y -->
                    <!-- Print Shift Y -->
                    <TextBlock Text="Print Shift_Y(mm)"
           Grid.Row="9"
           VerticalAlignment="Center"/>

                    <Grid Grid.Row="9"
      Grid.Column="1"
      Grid.ColumnSpan="2"
      Margin="0,10,0,0">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Button Content="-"
            Width="25"
            Click="BtnShiftMinusY1_Click"/>

                        <TextBox x:Name="TxtPrintShiftY1"
             Grid.Column="1"
             Height="23"
             HorizontalContentAlignment="Center"/>

                        <Button Content="+"
            Grid.Column="2"
            Width="25"
            Click="BtnShiftPlusSmallY1_Click"/>

                        <Button Content=">>"
            Grid.Column="4"
            Width="50"
            Click="BtnShiftPlusY1_Click"/>

                    </Grid>

                    <TextBlock x:Name="LblPrintingpageY1"
           Grid.Row="10"
           Grid.ColumnSpan="3"
           Margin="0,5,0,0"
           FontWeight="Bold"
           Text="Current Value: 0.0"/>


                    <!-- Print Modes -->
                    <TextBlock Text="Print Modes"
                               Grid.Row="11"
                               Margin="0,12,0,0"/>

                    <ComboBox x:Name="CboPrintMode1"
                              Grid.Row="11"
                              Grid.Column="1"
                              Grid.ColumnSpan="2"
                              Margin="-50,12,0,0"
                              Height="23"
                              Width="250">
                        <ComboBoxItem Content="Change Print Modes"/>
                    </ComboBox>

                    <!-- Current Print Mode -->
                    <TextBlock x:Name="LblPrintMode1"
                               Grid.Row="12"
                               Grid.Column="1"
                               Grid.ColumnSpan="2"
                               Margin="0,12,0,0"
                               Text="Current Print Mode:"/>

                    <!-- Stop & Apply -->
                    <StackPanel Grid.Row="13"
            Grid.ColumnSpan="4"
            Orientation="Horizontal"
            HorizontalAlignment="Center"
            Margin="0,15,0,0">

                        <Button x:Name="BtnStartImages1"
            Content="START"
            Width="100"
            Height="35"
            Background="#27AE60"
            Foreground="White"
            FontWeight="Bold"
            Margin="0,0,10,0"
            Click="StartButton1_Click"/>

                        <Button x:Name="BtnStopImages1"
            Content="STOP"
            Width="100"
            Height="35"
            Background="#C0392B"
            Foreground="White"
            FontWeight="Bold"
            Margin="0,0,10,0"
            Click="StopButton1_Click"/>

                        <Button Content="Apply"
            Width="90"
            Height="35"
            Click="ApplyButton1_Click"/>

                    </StackPanel>

                    <!-- Speed -->
                    <TextBlock Text="Printing Speed:"
                               Grid.Row="15"
                               Margin="0,25,0,0"
                               FontWeight="Bold"
                               FontSize="20"/>

                    <TextBlock x:Name="LblSpeed1"
                               Grid.Row="15"
                               Grid.Column="1"
                               Grid.ColumnSpan="2"
                               Margin="0,25,0,0"
                               FontWeight="Bold"
                               FontSize="22"
                               Foreground="DarkBlue"
                               Text="0 m/min"/>

                </Grid>
            </GroupBox>
        </Grid>
    </Grid>
</Window>